+// ── Structured athlete portal Supabase source of truth ────────────────────────
+async function fetchCoachDataSB() {
+  const empty = {
+    ok: false,
+    body: [],
+    nutrition: [],
+    sessions: [],
+    weekly: [],
+    goals: [],
+    counts: {},
+  };
+
+  try {
+    const res = await fetch('/api/coach-data', { cache: 'no-store' });
+    if (!res.ok) return { ...empty, error: `HTTP ${res.status}` };
+
+    const data = await res.json();
+
+    return {
+      ok: data.ok === true,
+      error: data.error || null,
+      body: Array.isArray(data.body) ? data.body : [],
+      nutrition: Array.isArray(data.nutrition) ? data.nutrition : [],
+      sessions: Array.isArray(data.sessions) ? data.sessions : [],
+      weekly: Array.isArray(data.weekly) ? data.weekly : [],
+      goals: Array.isArray(data.goals) ? data.goals : [],
+      counts: data.counts || {},
+      generatedAt: data.generatedAt || null,
+    };
+  } catch (error) {
+    console.warn('fetchCoachDataSB failed', error);
+    return { ...empty, error: error.message };
+  }
+}
+
+function mergeByAthleteDate(portalRows, notionRows) {
+  const output = [];
+  const seen = new Set();
+
+  const dateOf = row =>
+    String(row['date:Date:start'] || row.Date || '').slice(0, 10);
+
+  const idOf = row =>
+    nid(row.AthleteID || row['Athlete Code'] || row._athleteCode || '');
+
+  const keyOf = row => `${idOf(row)}|${dateOf(row)}`;
+
+  for (const row of portalRows || []) {
+    const key = keyOf(row);
+    if (!key || key.startsWith('|') || seen.has(key)) continue;
+    seen.add(key);
+    output.push(row);
+  }
+
+  for (const row of notionRows || []) {
+    const key = keyOf(row);
+    if (!key || key.startsWith('|') || seen.has(key)) continue;
+    seen.add(key);
+    output.push(row);
+  }
+
+  return output;
+}
+
+function mergeSessionsPortalFirst(portalRows, notionRows) {
+  const dateOf = row => {
+    const raw = row.Date || row['date:Date:start'] || '';
+    const ddmm = String(raw).match(/^(\d{2})\/(\d{2})\/(\d{4})/);
+
+    if (ddmm) return `${ddmm[3]}-${ddmm[2]}-${ddmm[1]}`;
+
+    const iso = String(raw).split('T')[0];
+    if (iso) return iso;
+
+    const nameDate = String(row.Name || '').match(/(\d{4}-\d{2}-\d{2})$/);
+    return nameDate ? nameDate[1] : '';
+  };
+
+  const categoryOf = row =>
+    String(row['Session Category'] || row.Type || row.type || '').trim();
+
+  const idOf = row =>
+    sid(row) || nid(row.AthleteID || row['Athlete Code'] || '');
+
+  const nameOf = row =>
+    String(row.Session || row.session || '').trim().toLowerCase();
+
+  const keyOf = row =>
+    `${idOf(row)}|${nameOf(row)}|${categoryOf(row).toLowerCase()}|${dateOf(row)}`;
+
+  const portal = portalRows || [];
+  const portalKeys = new Set(portal.map(keyOf));
+  const notionOnly = (notionRows || []).filter(row => !portalKeys.has(keyOf(row)));
+
+  return [...portal, ...notionOnly];
+}
